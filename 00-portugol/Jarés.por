programa {
  funcao inicio() {
    inteiro caminhao
    real lucroCaminhao
    real lucro
    lucroCaminhao = (90 * 50) - 450
    //escreva (lucroCaminhao)
    escreva ("Quantos caminhões sairam? ")
    leia (caminhao)
    lucro = lucroCaminhao * caminhao
    escreva ("O lucro da temporada é de: " + lucro)
  }
}
