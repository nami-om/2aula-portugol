programa {
  funcao inicio() {
    inteiro idade,idadeAnos
    inteiro idadeHumano = 7
    escreva ("Qual a idade do seu cão? ")
    leia (idade)
    idadeAnos = idade * idadeHumano
    se(idadeAnos > 60){
      escreva ("Pode se aposentar")
      }senao{
        escreva ("Pode nada não")
      }
  }
}
